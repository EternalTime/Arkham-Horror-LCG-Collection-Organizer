{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AHLCG",
  "version": "0.1.0",
  "identifier": "com.sowinski.ahlcg",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Arkham Horror LCG - Collection",
        "url": "http://127.0.0.1:17845/index.html",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "backgroundColor": "#131318"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
